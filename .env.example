# Example environment variables for production
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=False
DATABASE_URL=postgres://user:password@host:5432/dbname
ALLOWED_HOSTS=.sevalla.app,yourdomain.com
CORS_ALLOWED_ORIGINS=https://your-frontend.sevalla.app
CORS_ALLOW_ALL_ORIGINS=False
CSRF_TRUSTED_ORIGINS=https://your-frontend.sevalla.app
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=supersecret
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_TEST_PHONE=
MPESA_ADMIN_TOKEN=
# Development Environment Variables
# Copy to .env.development.local for local development

# API Base URL (relative path works with Vite dev server proxy)
VITE_API_URL=/api

# For when you have Django running on a separate port
VITE_DEV_API_URL=http://localhost:8000/api
