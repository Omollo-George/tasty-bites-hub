# ============================================================================
# TASTY BITES HUB - SEVALLA DEPLOYMENT ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in all required values
# For local development, copy to .env.local or .env.development.local

# === DJANGO CORE SETTINGS ===
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-with-get_random_secret_key
ALLOWED_HOSTS=localhost,127.0.0.1,yourapp.sevalla.app,yourdomain.com
DATABASE_URL=postgresql://user:password@localhost:5432/tastybites_db

# === CORS & SECURITY ===
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourapp.sevalla.app
CORS_ALLOW_ALL_ORIGINS=False
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://yourapp.sevalla.app
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True

# === M-PESA SANDBOX (Testing) ===
MPESA_CONSUMER_KEY=your-sandbox-consumer-key
MPESA_CONSUMER_SECRET=your-sandbox-consumer-secret
MPESA_SHORTCODE=123456
MPESA_EXPRESS_SHORTCODE=123456
MPESA_PASSKEY=your-sandbox-passkey
MPESA_ENVIRONMENT=sandbox
MPESA_TO_KES_RATE=1

# === M-PESA PRODUCTION (Uncomment and update for live deployment) ===
# MPESA_CONSUMER_KEY=your-production-consumer-key
# MPESA_CONSUMER_SECRET=your-production-consumer-secret
# MPESA_ENVIRONMENT=production

# === M-PESA COMMON SETTINGS ===
# Callback URL must be HTTPS and publicly accessible
MPESA_CALLBACK_URL=https://yourapp.sevalla.app/api/payments/callback/

# Admin API security token (generate a secure random string for admin endpoints)
MPESA_ADMIN_TOKEN=your-secure-admin-token-here

# Test phone number for sandbox (e.g., 254700000000)
MPESA_TEST_PHONE=254700000000

# === EMAIL CONFIGURATION (Optional) ===
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# === FRONTEND (Vite) CONFIGURATION ===
# Base URL for API calls - can be relative path (proxied in dev) or absolute URL
VITE_API_URL=/api
VITE_CURRENCY_CODE=KES
VITE_CURRENCY_SYMBOL=KES

# For local development with separate Django/Vite servers
VITE_DEV_API_URL=http://localhost:8000/api

# === SERVER CONFIGURATION ===
PORT=8000
WORKERS=2

# === LOGGING & MONITORING (Optional) ===
SENTRY_DSN=
LOG_LEVEL=INFO
