{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["./src/*"]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node", "vitest"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "shared/**/*.ts", "client/**/*.ts", "tailwind.config.ts", "vite.config.ts", "vitest.workspace.ts", "env.d.ts"],
  "exclude": ["node_modules", "tastybites", "dist", "client/dist"]
}