{
  "version": 2,
  "buildCommand": "cd backend/tastybites && python manage.py migrate --noinput || true",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/api/index.py",
      "use": "@vercel/python",
      "config": { 
        "runtime": "python3.12",
        "requirements": "backend/tastybites/requirements.txt"
      }
    }
  ],
  "routes": [
    {
      "src": "^/api(/.*)?$",
      "dest": "/backend/api/index.py"
    },
    {
      "src": "^/payments(/.*)?$",
      "dest": "/backend/api/index.py"
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "^/favicon\\.svg$",
      "dest": "/frontend/favicon.svg"
    },
    {
      "src": "^/logo\\.svg$",
      "dest": "/frontend/logo.svg"
    },
    {
      "src": "^/robots\\.txt$",
      "dest": "/frontend/robots.txt"
    },
    {
      "src": "^/_redirects$",
      "dest": "/frontend/_redirects"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*)$",
      "dest": "/frontend/index.html"
    }
  ]
}